---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import { calculateReadingTime } from '../../utils';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import { pillarNames, pillarDescriptions } from '../../utils/index';

export async function getStaticPaths() {
  return Object.keys(pillarNames).map(pillar => ({ params: { pillar } }));
}

const { pillar } = Astro.params;



const aiStartHere = [
  {
    title: 'AI for Desktop Engineers: Practical Enterprise Guide',
    href: '/ai/ai-for-desktop-engineers-practical-enterprise-guide/',
    note: 'Foundational strategy and safe AI adoption model for endpoint teams.'
  },
  {
    title: 'Using AI to Generate Intune Detection Rules',
    href: '/ai/using-ai-to-generate-intune-detection-rules/',
    note: 'Prompt templates and validation workflow for production-safe detection logic.'
  },
  {
    title: 'How to Prompt AI to Write Secure PowerShell',
    href: '/ai/how-to-prompt-ai-to-write-secure-powershell/',
    note: 'A practical checklist to turn AI output into enterprise-ready scripts.'
  }
];

const aiClusters = [
  {
    name: 'Intune + AI',
    points: ['AI-generated detection rules', 'AI-assisted remediation scripts', 'Policy design and review prompts']
  },
  {
    name: 'SCCM + AI',
    points: ['AI log triage for client/install failures', 'Task sequence troubleshooting prompts', 'Patch rollout risk checks']
  },
  {
    name: 'PowerShell + AI',
    points: ['Prompt-to-script workflow', 'Security/code-review checklist', 'Automation refactoring patterns']
  },
  {
    name: 'Troubleshooting + AI',
    points: ['CMTrace/ProcMon pattern extraction', 'Root-cause hypotheses', 'Safe log redaction before analysis']
  },
  {
    name: 'Governance + Security',
    points: ['AI usage policy for endpoint teams', 'Data handling boundaries', 'Auditability and change control']
  }
];

// Get all articles for this pillar
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const pillarArticles = allArticles
  .filter(a => a.data.pillar === pillar)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const difficulties = ['junior', 'mid', 'senior'];
const types = ['war-story', 'deep-dive', 'how-to', 'script-drop', 'error-reference', 'opinion', 'career-guide'];
---

<BaseLayout title={pillarNames[pillar]} description={pillarDescriptions[pillar]}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-heading font-bold mb-4">{pillarNames[pillar]}</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">{pillarDescriptions[pillar]}</p>
    </div>
    

    {pillar === 'ai' && (
      <>
        <section class="mb-10 rounded-xl border border-purple-200 dark:border-purple-800 bg-purple-50/70 dark:bg-purple-950/30 p-6">
          <h2 class="text-2xl font-heading font-bold mb-3">AI for Desktop Engineers: Practical Enterprise Guide</h2>
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            This pillar helps endpoint teams apply AI safely and usefully in production: faster troubleshooting, better scripting,
            stronger governance, and repeatable workflows.
          </p>
          <div class="grid md:grid-cols-3 gap-4">
            {aiStartHere.map(item => (
              <a href={item.href} class="block rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-4 hover:border-accent">
                <h3 class="font-semibold mb-1">{item.title}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">{item.note}</p>
              </a>
            ))}
          </div>
        </section>

        <section class="mb-10">
          <h2 class="text-xl font-heading font-bold mb-4">Cluster Map</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {aiClusters.map(cluster => (
              <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
                <h3 class="font-semibold mb-2">{cluster.name}</h3>
                <ul class="list-disc pl-5 text-sm text-gray-700 dark:text-gray-300">
                  {cluster.points.map(point => <li>{point}</li>)}
                </ul>
              </div>
            ))}
          </div>
        </section>
      </>
    )}

    <!-- Filters -->
    <div class="flex flex-wrap gap-4 mb-8">
      <select id="difficulty-filter" aria-label="Filter by difficulty" class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg">
        <option value="">All Levels</option>
        {difficulties.map(d => (
          <option value={d}>{d.charAt(0).toUpperCase() + d.slice(1)}</option>
        ))}
      </select>
      
      <select id="type-filter" aria-label="Filter by type" class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg">
        <option value="">All Types</option>
        {types.map(t => (
          <option value={t}>{t.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}</option>
        ))}
      </select>
    </div>
    
    <!-- Articles Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="articles-grid">
      {pillarArticles.length > 0 ? (
        pillarArticles.map(article => (
          <div class="article-item" data-difficulty={article.data.difficulty} data-type={article.data.type}>
            <ArticleCard article={{ ...article.data, slug: article.slug, readingTime: calculateReadingTime(article.body || article.data.description || '') }} />
          </div>
        ))
      ) : (
        <p class="text-gray-500 col-span-full">No articles yet. Coming soon!</p>
      )}
    </div>
    
    <!-- Pagination -->
    <div id="pagination" class="mt-8 flex justify-center items-center gap-2 hidden">
      <button id="prev-btn" class="px-4 py-2 bg-gray-200 dark:bg-gray-700 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">&larr; Previous</button>
      <span id="page-info" class="text-sm text-gray-600 dark:text-gray-400 px-2"></span>
      <button id="next-btn" class="px-4 py-2 bg-gray-200 dark:bg-gray-700 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">Next &rarr;</button>
    </div>
  </div>
</BaseLayout>

<script>
  const PAGE_SIZE = 12;
  let currentPage = 1;
  let visibleItems: HTMLElement[] = [];

  const difficultyFilter = document.getElementById('difficulty-filter') as HTMLSelectElement;
  const typeFilter = document.getElementById('type-filter') as HTMLSelectElement;
  const allItems = Array.from(document.querySelectorAll('.article-item')) as HTMLElement[];
  const pagination = document.getElementById('pagination');
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const pageInfo = document.getElementById('page-info');

  function applyFilters() {
    const difficulty = difficultyFilter?.value || '';
    const type = typeFilter?.value || '';
    visibleItems = allItems.filter(item => {
      const matchesDifficulty = !difficulty || item.getAttribute('data-difficulty') === difficulty;
      const matchesType = !type || item.getAttribute('data-type') === type;
      return matchesDifficulty && matchesType;
    });
    currentPage = 1;
    renderPage();
  }

  function renderPage() {
    const totalPages = Math.max(1, Math.ceil(visibleItems.length / PAGE_SIZE));
    const start = (currentPage - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;

    allItems.forEach(item => item.style.display = 'none');
    visibleItems.slice(start, end).forEach(item => item.style.display = 'block');

    if (pagination) {
      if (visibleItems.length > PAGE_SIZE) {
        pagination.classList.remove('hidden');
      } else {
        pagination.classList.add('hidden');
      }
    }

    if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
  }

  prevBtn?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderPage(); window.scrollTo({ top: 0, behavior: 'smooth' }); } });
  nextBtn?.addEventListener('click', () => { currentPage++; renderPage(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
  difficultyFilter?.addEventListener('change', applyFilters);
  typeFilter?.addEventListener('change', applyFilters);

  applyFilters();
</script>

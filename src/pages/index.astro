---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({data}) => !data.draft);

const pillars = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>`,
    name: "Windows Troubleshooting",
    href: "/troubleshooting/",
    desc: "Boot failures, BSOD, event log forensics, profile corruption, error codes"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    name: "Scripting & Automation",
    href: "/scripting/",
    desc: "PowerShell, Graph API, task automation, scheduled jobs"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>`,
    name: "Deployment & Imaging",
    href: "/deployment/",
    desc: "Autopilot, WinPE, MDT, driver injection, provisioning"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    name: "Endpoint Security",
    href: "/security/",
    desc: "CIS benchmarks, LAPS, Defender for Endpoint, BitLocker, Conditional Access"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>`,
    name: "App Packaging",
    href: "/packaging/",
    desc: "Win32/Intune packaging, PSADT, silent installs, detection rules"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" /></svg>`,
    name: "Career & Craft",
    href: "/career/",
    desc: "Career progression, lab setup, cert roadmaps, documentation, tooling"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" /></svg>`,
    name: "AI-Augmented Engineering",
    href: "/ai/",
    desc: "Practical AI workflows for Intune, SCCM, PowerShell, and enterprise troubleshooting"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-sky-500"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
    name: "Trainings & Certificates",
    href: "/trainings/",
    desc: "Professional certifications and training records in AI, cloud, and IT infrastructure"
  },
];

const activePillars = pillars.filter(p => {
  const pillarSlug = p.href.replace(/\//g, '');
  return allArticles.some(a => a.data.pillar === pillarSlug);
});

const totalArticles = allArticles.length;
const aiArticles = allArticles.filter(a => a.data.pillar === 'ai').length;

const recentArticles = allArticles
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 4);
---

<BaseLayout title="Home" description="IT Desktop Engineering Blog — Technical articles, PowerShell scripts, and career guides for endpoint engineers.">

  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-800">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 text-gray-900 dark:text-white">
        Modern Desktop Engineering in the AI Era
      </h1>
      <p class="text-xl md:text-2xl font-semibold text-gray-700 dark:text-gray-200 mb-4">
        Advanced Microsoft Intune, SCCM, PowerShell, and AI-driven automation strategies for real-world enterprise environments.
      </p>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-6 max-w-4xl mx-auto">
        Learn practical endpoint management, automation, and security techniques used by professional desktop engineers.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a href="/ai/" class="px-6 py-3 rounded-lg bg-accent text-white font-semibold hover:opacity-90 transition">Explore Guides</a>
        <a href="/ai/" class="px-6 py-3 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-800 dark:text-gray-100 font-semibold hover:bg-gray-100 dark:hover:bg-gray-800 transition">Get the AI Toolkit</a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <div class="flex justify-center gap-8 py-8 border-y border-gray-100 dark:border-gray-800 text-center">
    <div><p class="text-2xl font-bold text-sky-500">{totalArticles}+</p><p class="text-sm text-gray-500">Articles</p></div>
    <div><p class="text-2xl font-bold text-sky-500">{aiArticles}+</p><p class="text-sm text-gray-500">AI Guides</p></div>
    <div><p class="text-2xl font-bold text-sky-500">7</p><p class="text-sm text-gray-500">Topics</p></div>
    <div><p class="text-2xl font-bold text-sky-500">Free</p><p class="text-sm text-gray-500">Always</p></div>
  </div>

  <!-- Pillars Grid -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-gray-900 dark:text-white">
        Explore by Topic
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {activePillars.map((pillar) => {
          const pillarSlug = pillar.href.replace(/\//g, '');
          const count = allArticles.filter(a => a.data.pillar === pillarSlug).length;
          return (
            <div class="pillar-card bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 hover:border-accent dark:hover:border-accent transition-colors transition-transform duration-200 hover:-translate-y-1 hover:shadow-lg group">
              <div class="flex items-start gap-4 mb-4">
                <span set:html={pillar.icon}></span>
                <div>
                  <h3 class="text-lg font-bold group-hover:text-accent transition-colors">
                    <a href={pillar.href}>{pillar.name}</a>
                  </h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400">{pillar.desc}</p>
                  <span class="text-xs text-gray-400 mt-1">{count} articles</span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  {recentArticles.length > 0 && (
    <section class="py-12 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Latest Articles</h2>
          <a href="/ai/" class="text-sky-500 hover:text-sky-600 font-medium transition-colors">View all →</a>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {recentArticles.map((article) => (
            <a href={`/${article.data.pillar}/${article.slug}/`} class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 hover:border-accent dark:hover:border-accent transition-colors hover:shadow-md group block">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs px-2 py-0.5 rounded-full bg-sky-100 dark:bg-sky-900 text-sky-700 dark:text-sky-300 font-medium capitalize">{article.data.pillar}</span>
                {article.data.difficulty && (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 font-medium capitalize">{article.data.difficulty}</span>
                )}
              </div>
              <h3 class="text-base font-bold text-gray-900 dark:text-white group-hover:text-accent transition-colors mb-2">{article.data.title}</h3>
              {article.data.description && (
                <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{article.data.description}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .pillar-card {
    animation: fadeInUp 0.4s ease forwards;
    opacity: 0;
  }
  .pillar-card:nth-child(1) { animation-delay: 0ms; }
  .pillar-card:nth-child(2) { animation-delay: 80ms; }
  .pillar-card:nth-child(3) { animation-delay: 160ms; }
  .pillar-card:nth-child(4) { animation-delay: 240ms; }
  .pillar-card:nth-child(5) { animation-delay: 320ms; }
  .pillar-card:nth-child(6) { animation-delay: 400ms; }
  .pillar-card:nth-child(7) { animation-delay: 480ms; }
  .pillar-card:nth-child(8) { animation-delay: 560ms; }
</style>
